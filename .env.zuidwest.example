# ZuidWest FM Configuration
# Based on .env.example with defaults we don't need to override deleted

# ====================
# STATION IDENTITY
# ====================
STATION_ID=zuidwest
STATION_NAME=ZuidWest FM

# ====================
# ICECAST STREAMING
# ====================
ICECAST_HOST=icecast.zuidwest.cloud
ICECAST_PORT=80
ICECAST_SOURCE_PASSWORD=hackme

# ====================
# SRT STUDIO INPUTS
# ====================
SRT_PASSPHRASE=foxtrot-uniform-charlie-kilo

# ====================
# AUDIO FALLBACK & SILENCE DETECTION
# ====================
EMERGENCY_AUDIO_PATH=/audio/fallback.ogg
SILENCE_SWITCH_SECONDS=10.0

# ====================
# STEREOTOOL AUDIO PROCESSING
# ====================
STEREOTOOL_LICENSE=<xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx>

# ====================
# DAB+ DIGITAL RADIO
# ====================
DAB_BITRATE=96
DAB_EDI_DESTINATIONS=tcp://localhost:9001,tcp://localhost:9002
DAB_METADATA_SIZE=8
DAB_METADATA_SOCKET=padenc.sock

# ====================
# HLS OUTPUT
# ====================
# HLS_BUNNY_STORAGE_ZONE=zwfm-hls
# HLS_BUNNY_ACCESS_KEY=<bunny-edge-storage-read-write-password>
# HLS_BUNNY_ENDPOINT=storage.bunnycdn.com
# HLS_METADATA_BIND=127.0.0.1
# HLS_METADATA_PORT=7000
# HLS_METADATA_BEARER_TOKEN=<long-random-token>
