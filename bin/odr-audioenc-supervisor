#!/bin/sh

# Publishes its own PID for dab-tcp-ack-monitor, then execs ODR-AudioEnc in
# place so stdin, stderr, signals and the exit status pass through natively.
# The PID file may outlive the encoder; the monitor detects that with kill -0.

set -eu

ODR_AUDIOENC_BIN=${ODR_AUDIOENC_BIN:-/bin/odr-audioenc}
ODR_AUDIOENC_PID_FILE=${ODR_AUDIOENC_PID_FILE:-/tmp/dab-ack-monitor/audioenc.pid}

pid_dir=${ODR_AUDIOENC_PID_FILE%/*}
if [ "${pid_dir}" = "${ODR_AUDIOENC_PID_FILE}" ]; then
  pid_dir=.
fi

umask 077
mkdir -p -- "${pid_dir}"

printf '%s\n' "$$" > "${ODR_AUDIOENC_PID_FILE}.$$"
mv -f -- "${ODR_AUDIOENC_PID_FILE}.$$" "${ODR_AUDIOENC_PID_FILE}"

exec "${ODR_AUDIOENC_BIN}" "$@"
